# IOTA
IOTA_NETWORK=testnet
IOTA_RPC_URL=https://api.testnet.iota.org
IOTA_TESTNET_RPC_URL=https://api.testnet.iota.org
IOTA_MAINNET_RPC_URL=https://api.mainnet.iota.org
IOTA_PRIVATE_KEY=REPLACE_WITH_IOTA_PRIVATE_KEY
IOTA_PACKAGE_ID=0xREPLACE_WITH_TESTNET_PACKAGE_ID
IOTA_TESTNET_PACKAGE_ID=0xREPLACE_WITH_TESTNET_PACKAGE_ID
IOTA_MAINNET_PACKAGE_ID=0xREPLACE_WITH_MAINNET_PACKAGE_ID
IOTA_MODULE=proof
IOTA_ANCHOR_ONCHAIN=true
IOTA_ISSUER_ADDRESS=0xREPLACE_WITH_ISSUER_ADDRESS

# Mainnet safety
IOTA_MAINNET_ENABLED=false
IOTA_MAINNET_CONFIRM_TOKEN=REPLACE_WITH_MAINNET_CONFIRM_TOKEN

# Storage / gateway
NEXT_PUBLIC_GATEWAY_URL=https://REPLACE_WITH_GATEWAY_HOST
PINATA_JWT=REPLACE_WITH_PINATA_JWT

# Supabase
SUPABASE_URL=https://REPLACE_WITH_SUPABASE_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public
DATABASE_URL=postgresql://REPLACE_WITH_DB_USER:REPLACE_WITH_DB_PASSWORD@REPLACE_WITH_DB_HOST:6543/postgres

# API auth
API_KEY_AUTH_MODE=soft
API_KEY_PLAIN=REPLACE_WITH_TEST_API_KEY

# Request limits
MAX_MULTIPART_BYTES=10485760
MAX_JSON_BYTES=5242880
MAX_VERIFY_JSON_BYTES=2097152
MAX_VERIFY_QUERY_BYTES=16384
MAX_PHOTO_BYTES=5242880
