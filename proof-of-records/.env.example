# ==============================
# IOTA CONFIG (TESTNET)
# ==============================

IOTA_NETWORK=testnet
IOTA_RPC_URL=https://api.testnet.iota.org

# Private key used for anchoring
IOTA_PRIVATE_KEY=

# Smart contract config
IOTA_PACKAGE_ID=
IOTA_MODULE=proof

# Optional issuer address
IOTA_ISSUER_ADDRESS=

# Keep on-chain anchoring enabled for the intended demo flow
IOTA_ANCHOR_ONCHAIN=true

# ==============================
# SUPABASE
# ==============================

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# STORAGE / GATEWAY
# ==============================

# Public gateway used to open stored evidence
NEXT_PUBLIC_GATEWAY_URL=

# Required only if you want to upload photo evidence to IPFS/Pinata
PINATA_JWT=

# ==============================
# DATABASE
# ==============================

DATABASE_URL=

# ==============================
# OPTIONAL SETTINGS
# ==============================

# API key mode for demo usage: off | soft | required
API_KEY_AUTH_MODE=soft

# Request limits (runtime expects bytes; defaults below are judge-friendly)
MAX_MULTIPART_BYTES=10485760
MAX_JSON_BYTES=5242880
MAX_PHOTO_BYTES=5242880
